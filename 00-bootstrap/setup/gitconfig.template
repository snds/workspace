# Global git config — uses includeIf to apply identity by directory.
# Personal repos under ~/personal/** or ~/Projects/**, work repos under ~/work/**.
# Repos outside all routed directories use repo-local config (e.g., the Claude Workspace).

[init]
	defaultBranch = main

[pull]
	rebase = false

[rebase]
	# NEVER auto-stash on rebase/pull. With this off, a `git pull --rebase` over a
	# dirty working tree REFUSES (safe) instead of stashing your uncommitted work and
	# risking a stranded stash on a pop conflict. This protects a live editing session
	# from the cross-machine auto-sync. Do not enable autoStash for the workspace.
	autoStash = false

[push]
	default = current

[fetch]
	prune = true

[core]
	excludesFile = ~/.gitignore_global

# Directory-routed identity.
# The trailing slash in the pattern is required for gitdir matching.

[includeIf "gitdir:~/personal/"]
	path = ~/.gitconfig.personal

[includeIf "gitdir:~/Projects/"]
	path = ~/.gitconfig.personal

[includeIf "gitdir:~/work/"]
	path = ~/.gitconfig.work
