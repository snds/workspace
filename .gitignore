# Claude Workspace — scoped Git tracking.
# We track the SYSTEM LAYER only: context, frameworks, skills, preferences,
# bootstrap (installer + integration docs + Obsidian templates), vault config,
# CLAUDE.md, MOCs, and the 00-obsidian project (this integration's docs).
# Everything else is intentionally excluded — artifacts, project work, tools, vendor files.

# ---- Ignore by default ----
*

# ---- But track these ----
!.gitignore
!.gitattributes

# Universal agent contract + per-tool adapters (portable, LLM-agnostic layer).
!AGENTS.md
!CLAUDE.md
!PERPLEXITY.md
!CURSOR.md
!README.md
!llms.txt

# Maps of Content (Obsidian navigation layer)
!_HOME.md
!_MOC.md
!_PROJECTS.md
!_SKILLS.md
!_FRAMEWORKS.md
!_CONTEXT.md
!_CHEATSHEET.md

!.claude/
!.claude/**

!.cursor/
!.cursor/**

!.obsidian/
!.obsidian/**

!.github/
!.github/**

!00-bootstrap/
!00-bootstrap/**

!01-frameworks/
!01-frameworks/**

!02-shared-references/
!02-shared-references/**

!03-skills/
!03-skills/**

!04-preferences/
!04-preferences/**

!06-context/
!06-context/**

# Archive (retired files + provenance ledger). Tracked so provenance is auditable.
!_archive/
!_archive/**

!08-knowledge/
!08-knowledge/**

# 09-tools/ stays mostly local (vendor + per-machine tools), but selectively
# track the cross-machine, portable utilities so they're version-controlled.
!09-tools/
!09-tools/README.md
!09-tools/build-registry.py
!09-tools/build-related.py
!09-tools/validate-links.py
!09-tools/validate-workspace.py
!09-tools/validate-integrity.py
!09-tools/validate-capabilities.py
!09-tools/compile-cursor-rules.py
!09-tools/build-local-skill-plugin.py

# Track only the 00-obsidian integration project; other projects stay local.
!07-projects/
!07-projects/00-obsidian/
!07-projects/00-obsidian/**

# Track the portable bootstrap generator — pilot for git-native (non-gdrive) projects.
!07-projects/18-bootstrap-generator/
!07-projects/18-bootstrap-generator/**

# ---- Still ignored, even inside tracked folders ----

# Per-user permission grants (machine-local; never share)
.claude/settings.local.json
**/settings.local.json

# Claude Code transient
.claude/sessions/
.claude/logs/
.claude/projects/

# Claude Code per-session worktrees (auto-generated, machine-local)
**/.claude/worktrees/

# Per-machine dispatcher state (claude-version pin, etc.)
.claude/state/

# Obsidian runtime state (per-device, not shared)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/graph-*.json.bak

# Obsidian plugin runtime data — auto-modified while Obsidian is open, not user-authored
.obsidian/core-plugins.json
.obsidian/plugins/*/data.json

# Obsidian plugin binaries — installed by setup.py, not versioned
.obsidian/plugins/*/main.js
.obsidian/plugins/*/manifest.json
.obsidian/plugins/*/styles.css

# Daily notes — local to each machine
05-artifacts/active/daily/

# Google Drive metadata + virtual shortcuts (not real bytes; git can't read them)
**/desktop.ini
**/.DS_Store
**/*.gdoc
**/*.gsheet
**/*.gslides
**/*.gform
**/*.gdraw
**/*.gtable
**/*.glink
**/*.gnote
**/*.gscript
**/*.gmap
**/*.gjam

# OS temp files
**/Thumbs.db
**/*.swp
**/*~

# Python bytecode
**/__pycache__/
**/*.pyc

# macOS custom folder-icon files (Google Drive / Finder create these in every
# folder; they pollute git status and block `git pull --rebase` every session).
Icon?
**/Icon?
