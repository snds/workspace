# Normalize line endings. Markdown and text use LF; shell/python scripts force LF.
* text=auto eol=lf
*.md text eol=lf
*.json text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.command text eol=lf

# Windows batch files keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.pdf binary
*.ico binary
