#!/usr/bin/env python3
"""Direct runner for wsx (no install needed): `python3 generator/bin/wsx <cmd>`.

Adds the generator/ dir to sys.path so `wsxlib` imports, then dispatches. For an
installed entry point instead, `pip install -e generator` exposes `wsx` (see pyproject.toml).
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from wsxlib.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
