{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bootstrap-gen/schemas/profile.schema.json",
  "title": "profile.yaml — the person (brain↔hands seam)",
  "description": "Produced/edited by the brain via `wsx profile set`; consumed by wsx. Stored as YAML in context/profile.yaml within the constrained subset wsxlib/yamlio.py supports (nested maps, scalars, inline flow lists).",
  "type": "object",
  "required": ["schema_version", "identity", "surfaces", "transport", "contexts", "lifecycle", "privacy"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string", "const": "0.2" },
    "identity": {
      "type": "object",
      "required": ["name", "handle"],
      "properties": {
        "name": { "type": "string" },
        "handle": { "type": "string" }
      }
    },
    "surfaces": {
      "type": "object",
      "description": "Which AI tools to emit for. 'primary' is the recommended/default surface.",
      "properties": {
        "primary": { "type": "string", "examples": ["claude", "cursor", "codex", "gemini"] },
        "agents": { "type": "array", "items": { "type": "string" } },
        "machines": { "type": "array", "items": { "type": "string" } }
      }
    },
    "models": {
      "type": "object",
      "properties": {
        "tier": { "type": "string", "enum": ["frontier", "mid", "small-local"] },
        "offline": { "type": "boolean" }
      }
    },
    "transport": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["git", "local"] },
        "remote": { "type": "string", "description": "git remote URL, or empty" }
      }
    },
    "contexts": {
      "type": "object",
      "description": "Walled by default: work/professional/personal kept separate; personal is private.",
      "properties": {
        "work": {
          "type": "object",
          "properties": {
            "role": { "type": "string" },
            "summary": { "type": "string" }
          }
        },
        "professional": {
          "type": "object",
          "properties": {
            "crafts": { "type": "array", "items": { "type": "string" } }
          }
        },
        "personal": {
          "type": "object",
          "properties": {
            "private": { "type": "boolean", "description": "true ⇒ local-only, never synced" },
            "interests": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "preferences": {
      "type": "object",
      "properties": {
        "tone": { "type": "string" },
        "verbosity": { "type": "string" },
        "audience": { "type": "string" },
        "banned": { "type": "array", "items": { "type": "string" }, "description": "anti-patterns to avoid" }
      }
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "continuity": { "type": "boolean" },
        "separation": { "type": "string", "enum": ["walled", "blended"] },
        "automation": { "type": "string", "enum": ["minimal", "standard", "full"] }
      }
    },
    "privacy": {
      "type": "object",
      "properties": {
        "personal_local_only": { "type": "boolean" },
        "encrypt": { "type": "boolean" }
      }
    },
    "imports": {
      "type": "array",
      "items": { "type": "string" },
      "description": "existing repos / skill libraries / docs to learn from"
    }
  }
}
