{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bootstrap-gen/schemas/manifest.schema.json",
  "title": "manifest.json — the routing index (brain↔hands seam)",
  "description": "Maintained by wsx. Indexes skills (for routing + overlap checks) and records what was emitted to each surface.",
  "type": "object",
  "required": ["schema_version", "generator", "skills"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string", "const": "0.2" },
    "generator": { "type": "string", "const": "wsx" },
    "workspace": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "created_with": { "type": "string" }
      }
    },
    "skills": {
      "type": "object",
      "description": "name -> routing record",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "hub": { "type": "string" },
          "triggers": { "type": "array", "items": { "type": "string" } },
          "source": { "type": "string", "enum": ["pulled", "pulled+patched", "generated"] },
          "hash": { "type": "string" }
        }
      }
    },
    "emitted": {
      "type": "object",
      "description": "target -> { files[], at }",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "files": { "type": "array", "items": { "type": "string" } },
          "at": { "type": "string" }
        }
      }
    }
  }
}
